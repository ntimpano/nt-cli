{
  "nt-leader": {
    "description": "NT Leader SDD Orchestrator - based on Gentle AI + Engram, adapted for nt-cli",
    "mode": "primary",
    "model": "github-copilot/claude-sonnet-4.6",
    "permission": {
      "task": {
        "*": "deny",
        "nt-spark": "allow",
        "nt-creative-expand": "allow",
        "nt-creative-focus": "allow",
        "nt-creative-shape": "allow",
        "nt-creative-polish": "allow",
        "nt-creative-ship": "allow",
        "nt-strategy-diagnose": "allow",
        "nt-strategy-options": "allow",
        "nt-strategy-decide": "allow",
        "nt-strategy-communicate": "allow",
        "nt-strategy-track": "allow",
        "nt-research-gather": "allow",
        "nt-research-synthesize": "allow",
        "nt-research-challenge": "allow",
        "nt-research-conclude": "allow",
        "nt-research-document": "allow",
        "nt-sdd-apply": "allow",
        "nt-sdd-archive": "allow",
        "nt-sdd-design": "allow",
        "nt-sdd-explore": "allow",
        "nt-sdd-init": "allow",
        "nt-sdd-onboard": "allow",
        "nt-sdd-propose": "allow",
        "nt-sdd-spec": "allow",
        "nt-sdd-tasks": "allow",
        "nt-sdd-verify": "allow"
      }
    },
    "prompt": "{file:/opt/nt-cli/prompts/sdd/nt-leader.md}",
    "tools": {
      "bash": true,
      "delegate": true,
      "delegation_list": true,
      "delegation_read": true,
      "edit": true,
      "read": true,
      "write": true
    }
  },
