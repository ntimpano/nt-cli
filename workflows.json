{
  "$schema": "https://nt-cli.dev/schemas/workflows/v1",
  "version": "1",
  "workflows": {
    "dev": {
      "description": "Software development with SDD",
      "tags": ["code", "structured", "planned"],
      "phases": ["spark", "explore", "propose", "spec", "design", "tasks", "apply", "verify", "archive"],
      "agents": ["nt-spark", "nt-sdd-explore", "nt-sdd-propose", "nt-sdd-spec", "nt-sdd-design", "nt-sdd-tasks", "nt-sdd-apply", "nt-sdd-verify", "nt-sdd-archive"]
    },
    "creative": {
      "description": "Creative work: writing, design, and content",
      "tags": ["creative", "divergent", "iterative"],
      "phases": ["spark", "expand", "focus", "shape", "polish", "ship"],
      "agents": ["nt-spark", "nt-creative-expand", "nt-creative-focus", "nt-creative-shape", "nt-creative-polish", "nt-creative-ship"]
    },
    "strategy": {
      "description": "Strategic planning and decision-making",
      "tags": ["decision", "analysis", "stakeholder"],
      "phases": ["brief", "diagnose", "options", "decide", "communicate", "track"],
      "agents": ["nt-strategy-brief", "nt-strategy-diagnose", "nt-strategy-options", "nt-strategy-decide", "nt-strategy-communicate", "nt-strategy-track"]
    },
    "research": {
      "description": "Research, analysis, and synthesis",
      "tags": ["evidence", "analysis", "synthesis"],
      "phases": ["question", "gather", "synthesize", "challenge", "conclude", "document"],
      "agents": ["nt-research-question", "nt-research-gather", "nt-research-synthesize", "nt-research-challenge", "nt-research-conclude", "nt-research-document"]
    }
  },
  "phases": {
    "spark": { "agent": "nt-spark", "capability": "intent-routing" },
    "explore": { "agent": "nt-sdd-explore", "capability": "problem-exploration" },
    "propose": { "agent": "nt-sdd-propose", "capability": "change-proposal" },
    "spec": { "agent": "nt-sdd-spec", "capability": "requirements-specification" },
    "design": { "agent": "nt-sdd-design", "capability": "technical-design" },
    "tasks": { "agent": "nt-sdd-tasks", "capability": "implementation-planning" },
    "apply": { "agent": "nt-sdd-apply", "capability": "implementation" },
    "verify": { "agent": "nt-sdd-verify", "capability": "spec-verification" },
    "archive": { "agent": "nt-sdd-archive", "capability": "change-closure" },
    "expand": { "agent": "nt-creative-expand", "capability": "divergent-ideation" },
    "focus": { "agent": "nt-creative-focus", "capability": "idea-selection" },
    "shape": { "agent": "nt-creative-shape", "capability": "structure-blueprint" },
    "polish": { "agent": "nt-creative-polish", "capability": "refinement" },
    "ship": { "agent": "nt-creative-ship", "capability": "final-packaging" },
    "brief": { "agent": "nt-strategy-brief", "capability": "decision-framing" },
    "diagnose": { "agent": "nt-strategy-diagnose", "capability": "root-cause-diagnosis" },
    "options": { "agent": "nt-strategy-options", "capability": "option-generation" },
    "decide": { "agent": "nt-strategy-decide", "capability": "option-selection" },
    "communicate": { "agent": "nt-strategy-communicate", "capability": "stakeholder-communication" },
    "track": { "agent": "nt-strategy-track", "capability": "execution-tracking" },
    "question": { "agent": "nt-research-question", "capability": "research-framing" },
    "gather": { "agent": "nt-research-gather", "capability": "evidence-collection" },
    "synthesize": { "agent": "nt-research-synthesize", "capability": "evidence-synthesis" },
    "challenge": { "agent": "nt-research-challenge", "capability": "adversarial-review" },
    "conclude": { "agent": "nt-research-conclude", "capability": "conclusion-formation" },
    "document": { "agent": "nt-research-document", "capability": "publication" }
  }
}
